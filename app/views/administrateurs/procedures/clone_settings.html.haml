= render partial: 'administrateurs/breadcrumbs',
  locals: { steps: [['Démarches', admin_procedures_back_path(@procedure)],
                    ["Cloner la démarche « #{@procedure.libelle.truncate_words(10)} » (N° #{@procedure.id})"]] }

.fr-container
  %h1
    = t('administrateurs.procedures.clone.title')
    = "« #{@procedure.libelle} » (N° #{@procedure.id})"

  = form_tag(admin_procedure_clone_path(@procedure), method: :put) do
    %h2.fr-h5.fr-mb-1w
      = t('administrateurs.procedures.clone.rename_title')
    = label_tag 'clone_options[libelle]', class: "fr-label" do
      = t('administrateurs.procedures.clone.libelle')
    = text_field_tag 'clone_options[libelle]', @procedure.libelle, required: true, class: "fr-input fr-mb-5w"

    %h2.fr-h5.fr-mb-2w
      = t('administrateurs.procedures.clone.configurate_title')

    %p.fr-alert.fr-alert--info.fr-alert--sm.fr-mb-3w
      = t('administrateurs.procedures.clone.info')

    %fieldset.fr-fieldset{id: "clone-options-checkboxes", aria: { labelledby: "clone-options-checkboxes" }}
      .fr-fieldset__element
        .fr-checkbox-group
          = check_box_tag 'clone_options[presentation]', '1', true
          = label_tag 'clone_options[presentation]', class: "fr-label" do
            = t('administrateurs.procedures.clone.presentation')
            .fr-hint-text
              = t('administrateurs.procedures.clone.presentation_hint')

      .fr-fieldset__element
        .fr-checkbox-group
          = check_box_tag 'clone_options[zones]', '1', true, id: 'clone_zones'
          = label_tag 'clone_options[zones]', class: "fr-label" do
            = t('administrateurs.procedures.clone.zones')
            .fr-hint-text
              = @procedure.zones.map(&:label).join(' | ')

      - if @is_same_admin
        .fr-fieldset__element
          .fr-checkbox-group
            = check_box_tag 'clone_options[service]', '1', false
            = label_tag 'clone_options[service]', class: "fr-label" do
              = t('administrateurs.procedures.clone.service')
              .fr-hint-text
                = @procedure.service&.nom

        .fr-fieldset__element
          .fr-checkbox-group
            = check_box_tag 'clone_options[administrateurs]', '1', false
            = label_tag 'clone_options[administrateurs]', class: "fr-label" do
              = t('administrateurs.procedures.clone.administrateurs')
              .fr-hint-text
                = t('administrateurs.procedures.clone.administrateurs_count', count: @procedure.administrateurs.count)

        .fr-fieldset__element
          .fr-checkbox-group
            = check_box_tag 'clone_options[instructeurs]', '1', false
            = label_tag 'clone_options[instructeurs]', class: "fr-label" do
              = t('administrateurs.procedures.clone.instructeurs')
              .fr-hint-text
                = t('administrateurs.procedures.clone.instructeurs_count', count: @procedure.groupe_instructeurs.map {_1.instructeurs.count }.sum)
                = t("administrateurs.procedures.clone.instructeurs_self_management.#{@procedure.instructeurs_self_management?.to_s}")
                = t("administrateurs.procedures.clone.routing_enabled.#{@procedure.routing_enabled.to_s}")

      .fr-fieldset__element
        .fr-checkbox-group
          = check_box_tag 'clone_options[champs]', '1', true
          = label_tag 'clone_options[champs]', class: "fr-label" do
            = t('administrateurs.procedures.clone.types_de_champ_public')
            .fr-hint-text
              = t('administrateurs.procedures.clone.types_de_champ_count', count: @procedure.active_revision.types_de_champ_public.count)

      .fr-fieldset__element
        .fr-checkbox-group
          = check_box_tag 'clone_options[annotations]', '1', true
          = label_tag 'clone_options[annotations]', class: "fr-label" do
            = t('administrateurs.procedures.clone.types_de_champ_private')
            .fr-hint-text
              = t('administrateurs.procedures.clone.types_de_champ_count', count: @procedure.active_revision.types_de_champ_private.count)

      .fr-fieldset__element
        .fr-checkbox-group
          = check_box_tag 'clone_options[ineligibilite]', '1', true
          = label_tag 'clone_options[ineligibilite]', class: "fr-label" do
            = t('administrateurs.procedures.clone.ineligibilite')
            .fr-hint-text
              = t("administrateurs.procedures.clone.ineligibilite_hint.#{@procedure.active_revision.ineligibilite_enabled.to_s}")

      .fr-fieldset__element
        .fr-checkbox-group
          = check_box_tag 'clone_options[monavis_embed]', '1', true
          = label_tag 'clone_options[monavis_embed]', class: "fr-label" do
            = t('administrateurs.procedures.clone.monavis_embed')
            .fr-hint-text
              = t('administrateurs.procedures.clone.monavis_embed_hint', code: @procedure.monavis_embed)

      .fr-fieldset__element
        .fr-checkbox-group
          = check_box_tag 'clone_options[dossier_submitted_message]', '1', true
          = label_tag 'clone_options[dossier_submitted_message]', class: "fr-label" do
            = t('administrateurs.procedures.clone.dossier_submitted_message')
            .fr-hint-text
              = t('administrateurs.procedures.clone.dossier_submitted_message_hint', message: @procedure.active_revision.dossier_submitted_message&.message_on_submit_by_usager)

      .fr-fieldset__element
        .fr-checkbox-group
          = check_box_tag 'clone_options[accuse_lecture]', '1', true
          = label_tag 'clone_options[accuse_lecture]', class: "fr-label" do
            = t('administrateurs.procedures.clone.accuse_lecture')
            .fr-hint-text
              = t("administrateurs.procedures.clone.accuse_lecture_hint.#{@procedure.accuse_lecture.to_s}")

      .fr-fieldset__element
        .fr-checkbox-group
          = check_box_tag 'clone_options[mail_templates]', '1', true
          = label_tag 'clone_options[mail_templates]', class: "fr-label" do
            = t('administrateurs.procedures.clone.mail_templates')
            .fr-hint-text
              = t('administrateurs.procedures.clone.mail_templates_hint')

      - if @procedure.sva_svr_enabled?
        .fr-fieldset__element
          .fr-checkbox-group
            = check_box_tag 'clone_options[sva_svr]', '1', true
            = label_tag 'clone_options[sva_svr]', class: "fr-label" do
              = t('administrateurs.procedures.clone.sva_svr')
              .fr-hint-text
                = t("administrateurs.procedures.clone.sva_svr_hint.#{@procedure.sva_svr_decision.to_s}")
                = t('administrateurs.procedures.clone.sva_svr_period', period: @procedure.sva_svr_configuration.period)
                = t("administrateurs.procedures.clone.sva_svr_unit_labels.#{@procedure.sva_svr_configuration.unit}")

      - if @procedure.experts_require_administrateur_invitation
        .fr-fieldset__element
          .fr-checkbox-group
            = check_box_tag 'clone_options[avis]', '1', true
            = label_tag 'clone_options[avis]', class: "fr-label" do
              = t('administrateurs.procedures.clone.avis')
              .fr-hint-text
                = t('administrateurs.procedures.clone.avis_hint')

      - if @procedure.attestation_template&.activated?
        .fr-fieldset__element
          .fr-checkbox-group
            = check_box_tag 'clone_options[attestation_template]', '1', true
            = label_tag 'clone_options[attestation_template]', class: "fr-label" do
              = t('administrateurs.procedures.clone.attestation_template')
              .fr-hint-text
                = t('administrateurs.procedures.clone.attestation_template_hint')

      - if @is_same_admin && @procedure.api_entreprise_token.present?
        .fr-fieldset__element
          .fr-checkbox-group
            = check_box_tag 'clone_options[api_entreprise_token]', '1', true
            = label_tag 'clone_options[api_entreprise_token]', class: "fr-label" do
              = t('administrateurs.procedures.clone.api_entreprise_token')
              .fr-hint-text
                = t('administrateurs.procedures.clone.api_entreprise_token_hint')

    .fixed-footer
      .fr-container
        %ul.fr-btns-group.fr-btns-group--inline-md.fr-ml-0
          %li
            = link_to t('administrateurs.procedures.clone.cancel'), admin_procedure_path(@procedure), class: 'fr-btn fr-btn--secondary fr-ml-0'
          %li
            = submit_tag t('administrateurs.procedures.clone.actions.clone'), class: 'fr-btn', data: { disable_with: t('administrateurs.procedures.clone.actions.disable_with') }
