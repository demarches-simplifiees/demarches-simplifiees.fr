- if display == 'true'
  .flex.align-center{ id: "notifications-button-#{@procedure_id}" }
    = link_to "Moins d'informations", instructeur_procedure_display_notifications_path(procedure_id: @procedure_id, display: 'false'), class: "fr-btn fr-btn--tertiary-no-outline fr-icon-arrow-up-s-line fr-btn--icon-right fr-btn--sm", data: { turbo: true }

- else
  .flex.align-center{ id: "notifications-button-#{@procedure_id}" }
    = link_to "Plus d'informations", instructeur_procedure_display_notifications_path(procedure_id: @procedure_id, display: 'true'), class: "fr-btn fr-btn--tertiary-no-outline fr-icon-arrow-down-s-line fr-btn--icon-right fr-btn--sm", data: { turbo: true }
